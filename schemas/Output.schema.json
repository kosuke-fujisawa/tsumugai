{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tsumugai/schemas/Output.schema.json",
  "title": "Tsumugai Runtime Output",
  "description": "runtime::step が返す Output の JSON 表現",
  "type": "object",
  "required": ["events", "waiting_for"],
  "additionalProperties": false,
  "properties": {
    "events": {
      "type": "array",
      "description": "このステップで発生したイベント列",
      "items": { "$ref": "#/$defs/Event" }
    },
    "waiting_for": {
      "description": "入力待ち状態。null なら次の step をそのまま呼んでよい",
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/WaitingType" }
      ]
    }
  },
  "$defs": {
    "Event": {
      "description": "ホスト側に通知するイベント（serde の外部タグ形式）",
      "oneOf": [
        {
          "type": "object",
          "required": ["Say"],
          "additionalProperties": false,
          "properties": {
            "Say": {
              "type": "object",
              "required": ["speaker", "text"],
              "additionalProperties": false,
              "properties": {
                "speaker": { "type": "string" },
                "text": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["SceneStart"],
          "additionalProperties": false,
          "properties": {
            "SceneStart": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["ShowImage"],
          "additionalProperties": false,
          "properties": {
            "ShowImage": {
              "type": "object",
              "required": ["layer", "name"],
              "additionalProperties": false,
              "properties": {
                "layer": { "type": "string" },
                "name": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["ClearLayer"],
          "additionalProperties": false,
          "properties": {
            "ClearLayer": {
              "type": "object",
              "required": ["layer"],
              "additionalProperties": false,
              "properties": {
                "layer": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["PlayBgm"],
          "additionalProperties": false,
          "properties": {
            "PlayBgm": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["PlaySe"],
          "additionalProperties": false,
          "properties": {
            "PlaySe": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["PlayMovie"],
          "additionalProperties": false,
          "properties": {
            "PlayMovie": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["Wait"],
          "additionalProperties": false,
          "properties": {
            "Wait": {
              "type": "object",
              "required": ["duration"],
              "additionalProperties": false,
              "properties": {
                "duration": { "type": "number" }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["Custom"],
          "additionalProperties": false,
          "properties": {
            "Custom": {
              "type": "object",
              "required": ["tag", "params"],
              "additionalProperties": false,
              "properties": {
                "tag": { "type": "string" },
                "params": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      ]
    },
    "WaitingType": {
      "description": "入力待ちの種類",
      "oneOf": [
        {
          "type": "object",
          "description": "進行入力待ち（Enter 待ち）",
          "required": ["Advance"],
          "additionalProperties": false,
          "properties": {
            "Advance": { "type": "null" }
          }
        },
        {
          "type": "object",
          "description": "選択肢入力待ち",
          "required": ["Choice"],
          "additionalProperties": false,
          "properties": {
            "Choice": {
              "type": "array",
              "items": { "$ref": "#/$defs/ChoiceOption" }
            }
          }
        }
      ]
    },
    "ChoiceOption": {
      "type": "object",
      "required": ["id", "label", "target_pc"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "選択肢ID（compile時に確定した一意のID）"
        },
        "label": {
          "type": "string",
          "description": "表示テキスト"
        },
        "target_pc": {
          "type": "integer",
          "minimum": 0,
          "description": "ジャンプ先のIRインデックス"
        }
      }
    }
  },
  "examples": [
    {
      "events": [
        { "Say": { "speaker": "Alice", "text": "こんにちは。" } }
      ],
      "waiting_for": { "Advance": null }
    },
    {
      "events": [],
      "waiting_for": {
        "Choice": [
          { "id": "root_branch_0_choice_0", "label": "はい", "target_pc": 3 },
          { "id": "root_branch_0_choice_1", "label": "いいえ", "target_pc": 6 }
        ]
      }
    },
    {
      "events": [
        { "PlayBgm": { "name": "battle.ogg" } },
        { "SceneStart": { "name": "battle" } }
      ],
      "waiting_for": null
    }
  ]
}
