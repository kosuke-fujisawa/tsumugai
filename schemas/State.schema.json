{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tsumugai/schemas/State.schema.json",
  "title": "Tsumugai Runtime State",
  "description": "types::State の JSON 表現（serde でシリアライズした場合）",
  "type": "object",
  "required": ["pc", "flags"],
  "additionalProperties": false,
  "properties": {
    "pc": {
      "type": "integer",
      "minimum": 0,
      "description": "IR上の現在実行位置（Program Counter）"
    },
    "flags": {
      "type": "object",
      "description": "変数・フラグのマップ。値は文字列・数値・真偽値のいずれか",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      }
    }
  },
  "examples": [
    {
      "pc": 0,
      "flags": {}
    },
    {
      "pc": 4,
      "flags": {
        "score": 10,
        "player_name": "Alice",
        "cleared": true
      }
    }
  ]
}
